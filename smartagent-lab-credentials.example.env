# Copy this file to smartagent-lab-credentials.env and replace the placeholder values.
# Source it in the shell that will run the Smart Agent demo commands.
# Keep the filled-in file local-only.

export SUPERVISOR_CONTROLLER_URL="customer.saas.appdynamics.com"
export SUPERVISOR_CONTROLLER_PORT="443"
export SUPERVISOR_ACCOUNT_NAME="your-account-name"
export SUPERVISOR_ACCOUNT_ACCESS_KEY="<your-account-access-key>"
export SUPERVISOR_ENABLE_SSL="true"

export SPLUNK_REALM="us1"
export SPLUNK_ACCESS_TOKEN="<your-splunk-access-token>"

# Optional convenience exports for the direct-to-Splunk variant.
export OTEL_EXPORTER_OTLP_HEADERS="x-sf-token=${SPLUNK_ACCESS_TOKEN}"
export OTEL_EXPORTER_OTLP_TRACES_ENDPOINT="https://ingest.${SPLUNK_REALM}.observability.splunkcloud.com/v2/trace/otlp"

# Optional password-auth variables for labs that do not use SSH keys.
# export SMARTAGENT_CONTROL_SSH_PASSWORD="<control-host-ssh-password>"
# export SMARTAGENT_MANAGED_SSH_PASSWORD="<managed-host-ssh-password>"
